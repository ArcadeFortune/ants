{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.2.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "jsdom": "npm:jsdom@^29.0.2"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2020", "deno.ns", "deno.unstable"]
  },
  "tasks": {
    "dev": "deno --inspect -A --env --unstable-bundle --watch --watch-exclude='.*/**/' ./server.ts",
    "build": "deno bundle ./public/index.html --outdir=./build --platform=browser --minify",
    "prod": "deno -A --env ./server.ts --prod",
    "test": "deno test -A"
  },
  "fmt": {
    "lineWidth": 2000,
    "semiColons": true
  }
}
